{
  "manifest_version": 3,
  "name": "Cookinc Bridge",
  "version": "1.0",
  "description": "Sync Chrome cookies to cookinc daemon",
  "permissions": ["cookies", "alarms"],
  "icons": {
    "16": "icons/icon16.png",
    "24": "icons/icon24.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "host_permissions": [
    "http://localhost:19999/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cookinc Bridge"
  }
}
